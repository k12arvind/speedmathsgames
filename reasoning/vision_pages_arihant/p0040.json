  "solutions": [
    {
      "number": 1,
      "solution": "(C) A 'Correspondent' gathers and formats 'News' for 'Newspaper' and similarly a 'Farmer' grows and reaps 'Crops' for 'Food'."
    },
    {
      "number": 2,
      "solution": "(d) All the three belong to the same class. 'Iron', 'Silver' and 'Gold' are all metals and similarly 'Dear', 'Lion' and 'Wolf' are all wild animals."
    },
    {
      "number": 3,
      "solution": "(c) 'Bus' moves on 'Road' and is driven by 'Driver'. Likewise 'Aeroplane' flies in the 'Sky' and is driven by 'Pilot'."
    },
    {
      "number": 4,
      "solution": "(b) 'Bangle' is meant for 'Wrist' which is a part of 'Hand'. Similarly, anklet is meant for 'Ankle' which is a part of 'Foot'."
    },
    {
      "number": 5,
      "solution": "(c) Music is performed with Guitar by the 'Performer'. Likewise, 'Trick' is performed with 'Rope' by the 'Acrobat'."
    },
    {
      "number": 6,
      "solution": "(c) 'Tragedy' has 'Sadness' and brings 'Tears'. Likewise 'Comedy' has 'Humour' and brings 'Laughter'."
    },
    {
      "number": 7,
      "solution": "(d) First is required to work with the second on the third."
    },
    {
      "number": 8,
      "solution": "(c) Third is a part of the first which, in turn, is a part of the second."
    },
    {
      "number": 9,
      "solution": "(c) First and third are both parts of the second."
    },
    {
      "number": 10,
      "solution": "(b) 'Lion' and 'Cow' are 'land' animals and similarly 'Whale' and 'Hippopotamus' are 'water' animals."
    }
